{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/daily-briefing",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/ar/aging-alert",
      "schedule": "30 13 * * *"
    },
    {
      "path": "/api/spinytails/ssop-reminder",
      "schedule": "0 15 * * *"
    },
    {
      "path": "/api/cashiers/weekly-digest",
      "schedule": "0 11 * * 1"
    },
    {
      "path": "/api/health-check",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/schema-integrity",
      "schedule": "30 10 * * *"
    },
    {
      "path": "/api/cron/vendor-weekly-statements",
      "schedule": "0 12 * * 1"
    },
    {
      "path": "/api/cron/customer-weekly-statements",
      "schedule": "0 12 * * 1"
    },
    {
      "path": "/api/cron/customer-weekly-statements",
      "schedule": "0 13 28-31 * *"
    },
    {
      "path": "/api/notifications/send",
      "schedule": "*/10 * * * *"
    }
  ]
}
